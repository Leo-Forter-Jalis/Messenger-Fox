<?xml version="1.0" encoding="UTF-8" ?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern=" %highlight{[%d{yyyy-MM-dd | HH:mm:ss}] [%thread | %logger{5}] %-5level - %msg%n}{ERROR=bright_red, WARN=bright_yellow, INFO=bright_green, DEBUG=bright_cyan, TRACE=bright_blue}"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="All">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>